#node_modules/vscode-test/

# === BUILD-DATEIEN IGNORIEREN ===
#esbuild.js
#tsconfig.test.json
#.gitignore

# === BUNDLE SIZE OPTIMIZATIONS ===
out/**/*.map
test/**
*.test.ts
# resources/tree-sitter/*.wasm  # NOT ignored: We need the WASM files at runtime for local AST Parsing!
