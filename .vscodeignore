# === ENTWICKLER-TOOLS IGNORIEREN ===
#.eslintrc.json
#.prettierrc*
#tsconfig.json
#vitest.config.ts
#scripts/
#docs/

# === SENSIBLE DATEIEN IGNORIEREN ===
.env
.env.*
#.vscode/
#.git/

# === LOGS UND TEMP ===
#logs/
#*.log
#tmp/
#dist/

# === TESTS IGNORIEREN ===
#test/
#**/*.test.ts
#**/*.spec.ts

# === GROSSE UNNÖTIGE NODE_MODULES AUSSCHLIESSEN ===
#node_modules/@types/
#node_modules/@typescript-eslint/
