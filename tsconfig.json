{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": [
      "ES2020"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "CLINE",
    "cline",
    "CLAUDE CODE",
    "claude code",
    "claude-code",
    "webview-ui",
    "dist",
    "test",
    "scripts",
    "repro_*.js",
    "vitest.config.ts"
  ]
}
